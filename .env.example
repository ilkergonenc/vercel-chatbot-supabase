# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# https://platform.openai.com/api-keys
OPENAI_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Supabase Postgres runtime URL. A pooled URL is supported.
DATABASE_URL=****

# Supabase Postgres direct/session URL for Drizzle migrations.
DIRECT_DATABASE_URL=****

# Legacy Postgres fallback during migration.
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
