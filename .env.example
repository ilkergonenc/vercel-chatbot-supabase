# https://platform.openai.com/api-keys
OPENAI_API_KEY=****

# Supabase project URL used for auth, database-related clients, and public Storage URLs.
NEXT_PUBLIC_SUPABASE_URL=****

# Supabase anon key used by browser and SSR auth clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=****

# Server-only key used by the upload route. Never expose this to client code.
SUPABASE_SERVICE_ROLE_KEY=****

# Public Supabase Storage bucket for chat attachments.
SUPABASE_STORAGE_BUCKET=chat-attachments

# Optional: set to true when chat-attachments is private. The chat API will
# generate short-lived signed URLs for OpenAI at request time.
SUPABASE_STORAGE_SIGNED_URLS=false
SUPABASE_STORAGE_SIGNED_URL_EXPIRES_IN=3600

# Optional: BotId is only enabled when this is set.
# BOTID_SECRET_KEY=****

# Supabase Postgres runtime URL. A pooled URL is supported.
DATABASE_URL=****

# Supabase Postgres direct/session URL for Drizzle migrations.
DIRECT_DATABASE_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
